{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": []
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/session-context.cjs\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd\" fluig-lint.sh",
            "timeout": 60,
            "statusMessage": "Verificando qualidade Fluig..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd\" fluig-ts-preference.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
